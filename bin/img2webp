#!/usr/bin/env zsh

isMacOS() {
  [[ "$(uname)" == "Darwin" ]]
}

if isMacOS; then
  if ! brew list | (grep -q  "^cwebp\$"; ret=$?; cat >/dev/null; exit $ret) then
    echo "cwebp is not installed. Please install it first using brew."
    exit 1
  fi
fi

if [ -z "$1" ]; then
  echo "USAGE : $0 <input> [output]"
  exit 1
fi

input="$1"

if [ -z "$2" ]; then
  output="${input%.*}.ico"
else
  output="$2"
fi

cwebp "$input" -o "$output"
